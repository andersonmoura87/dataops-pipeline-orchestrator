# Postgres credentials (used by docker-compose and the pipeline)
POSTGRES_USER=dataops
POSTGRES_PASSWORD=changeme
POSTGRES_DB=dataops

# Async SQLAlchemy DSN. When running outside compose, point host at localhost.
DATABASE_URL=postgresql+asyncpg://dataops:changeme@postgres/dataops

# How often the scheduler triggers a full run (hours)
SCHEDULE_HOURS=6

# Port for the Prometheus /metrics endpoint
METRICS_PORT=8080

# HTTP timeout (seconds) for external API calls
HTTP_TIMEOUT=30

LOG_LEVEL=INFO
